# Supabase — use Transaction pooler on Vercel (port 6543), NOT direct db.*:5432
# Example: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DATABASE_URL=

# Apple App Store Server API + product IDs (must match App Store Connect / iOS SubscriptionStore)
APPLE_BUNDLE_ID=
APPLE_ISSUER_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_ENVIRONMENT=sandbox
APPLE_MONTHLY_PRODUCT_ID=aidol.membership.monthly
APPLE_YEARLY_PRODUCT_ID=aidol.membership.yearly

# LLM proxy (OpenAI-compatible)
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# DashScope voice clone + TTS
DASHSCOPE_API_KEY=
# china = dashscope.aliyuncs.com (default; use with China console API key)
# intl = dashscope-intl.aliyuncs.com (only if your key is from the international console)
DASHSCOPE_REGION=china
DASHSCOPE_TTS_VC_MODEL=qwen3-tts-vc-2026-01-22
# Optional: raise defaults if cross-region latency is high (milliseconds)
# DASHSCOPE_CONNECT_TIMEOUT_MS=60000
# DASHSCOPE_HEADERS_TIMEOUT_MS=120000
# DASHSCOPE_BODY_TIMEOUT_MS=120000

# Optional quotas (defaults shown; values below code floors are ignored)
# Free tier floors in lib/membership.ts: chat 20, tts 5
FREE_DAILY_CHAT_LIMIT=20
FREE_DAILY_TTS_LIMIT=5
FREE_MONTHLY_VOICE_CLONE_LIMIT=3
MEMBER_DAILY_CHAT_LIMIT=200
MEMBER_DAILY_TTS_LIMIT=100
MEMBER_DAILY_THEATER_LIMIT=5
MEMBER_THEATER_PARTNER_REPLY_LIMIT=15
MEMBER_MONTHLY_VOICE_CLONE_LIMIT=10
